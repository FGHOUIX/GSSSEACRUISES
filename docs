<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GSS Adventure – Explore Ship</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.jsdelivr.net/npm/three@0.152.2/build/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.152.2/examples/js/controls/OrbitControls.js"></script>

<style>
html,body{
  margin:0;
  padding:0;
  background:#000;
  overflow:hidden;
  font-family:Segoe UI,sans-serif;
  color:#fff;
}

#hero{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  z-index:5;
  pointer-events:none;
}

#hero h1{font-size:64px;margin:0;}

#exploreBtn{
  position:absolute;
  bottom:40px;
  left:50%;
  transform:translateX(-50%);
  padding:14px 28px;
  background:#ffcc00;
  color:#000;
  font-weight:bold;
  cursor:pointer;
  z-index:6;
  border-radius:6px;
}

/* DECK */
#deckPlan{
  position:absolute;
  inset:0;
  background:#0a1a2a;
  display:none;
  z-index:20;
}

.deck-title{
  padding:20px;
  font-size:28px;
}

.cabin{
  position:absolute;
  background:#ffcc00;
  color:#000;
  padding:10px;
  cursor:pointer;
  font-weight:bold;
  border-radius:4px;
}

/* CABIN VIEW */
#cabinView,
#bookingPage{
  position:absolute;
  inset:0;
  background:#000;
  display:none;
  z-index:30;
}

#cabinView img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.overlay{
  position:absolute;
  bottom:40px;
  left:40px;
  background:rgba(0,0,0,.7);
  padding:20px;
  border-radius:8px;
}

button{
  padding:12px 20px;
  background:#ffcc00;
  border:none;
  font-weight:bold;
  cursor:pointer;
  margin-top:10px;
}

#close{
  position:absolute;
  top:20px;
  right:20px;
  background:red;
  padding:10px;
  cursor:pointer;
}
</style>
</head>

<body>

<div id="hero">
  <h1>GSS ADVENTURE</h1>
  <h2>Explore the Ship</h2>
</div>

<div id="exploreBtn" onclick="openDeck()">Explore Deck 12</div>

<div id="deckPlan">
  <div class="deck-title">Deck 12 – Deluxe Ocean View</div>

  <div class="cabin" style="top:120px;left:80px" data-cabin="12001">12001</div>
  <div class="cabin" style="top:120px;left:160px" data-cabin="12002">12002</div>
  <div class="cabin" style="top:120px;left:240px" data-cabin="12003">12003</div>
</div>

<!-- CABIN VIEW -->
<div id="cabinView">
  <div id="close" onclick="closeCabin()">CLOSE</div>
  <img id="cabinImg">
  <div class="overlay">
    <h2 id="cabinTitle"></h2>
    <p>Deluxe Ocean View – Front of Ship</p>
    <button onclick="openBooking()">Book This Cabin</button>
  </div>
</div>

<!-- BOOKING PAGE -->
<div id="bookingPage">
  <div class="overlay">
    <h2 id="bookingCabin"></h2>
    <p>Guest: Egor Stepanenko</p>
    <p>Manager: GSS Sea Cruises</p>
    <p>Price: $2,499 NZD</p>
    <button onclick="confirmBooking()">Pay & Confirm</button>
  </div>
</div>

<script>
const CABIN_IMAGE =
"https://images.unsplash.com/photo-1501117716987-c8e1ecb2108d";

let selectedCabin = "";

/* THREE */
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(60, innerWidth/innerHeight, .1, 1000);
camera.position.set(0,20,55);

const renderer = new THREE.WebGLRenderer({antialias:true});
renderer.setSize(innerWidth,innerHeight);
document.body.appendChild(renderer.domElement);

const controls = new THREE.OrbitControls(camera,renderer.domElement);
controls.enablePan=false;

scene.add(new THREE.AmbientLight(0xffffff,.7));
const sun = new THREE.DirectionalLight(0xffffff,1);
sun.position.set(50,80,40);
scene.add(sun);

const ocean = new THREE.Mesh(
  new THREE.PlaneGeometry(600,600),
  new THREE.MeshPhongMaterial({color:0x001f3f})
);
ocean.rotation.x=-Math.PI/2;
ocean.position.y=-6;
scene.add(ocean);

const ship=new THREE.Group();
scene.add(ship);

ship.add(new THREE.Mesh(
  new THREE.BoxGeometry(60,10,18),
  new THREE.MeshStandardMaterial({color:0xffffff})
));

function animate(){
  requestAnimationFrame(animate);
  ship.rotation.y+=0.0007;
  renderer.render(scene,camera);
}
animate();

/* UI */
function openDeck(){
  deckPlan.style.display="block";
  hero.style.display="none";
}

document.querySelectorAll(".cabin").forEach(c=>{
  c.onclick=()=>{
    selectedCabin=c.dataset.cabin;
    cabinTitle.innerText="Cabin "+selectedCabin;
    cabinImg.src=CABIN_IMAGE;
    deckPlan.style.display="none";
    cabinView.style.display="block";
  }
});

function closeCabin(){
  cabinView.style.display="none";
  deckPlan.style.display="block";
}

function openBooking(){
  cabinView.style.display="none";
  bookingPage.style.display="block";
  bookingCabin.innerText="Booking Cabin "+selectedCabin;
}

function confirmBooking(){
  alert("✅ You’re booked!\nCabin "+selectedCabin+"\nGSS Sea Cruises");
  bookingPage.style.display="none";
  deckPlan.style.display="block";
}

window.onresize=()=>{
  camera.aspect=innerWidth/innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
};
</script>

</body>
</html>

