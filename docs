<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GSS Adventure — Explore Ship</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.jsdelivr.net/npm/three@0.152.2/build/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.152.2/examples/js/controls/OrbitControls.js"></script>

<style>
html,body{
  margin:0;
  background:#000;
  overflow:hidden;
  font-family:Segoe UI,sans-serif;
  color:white;
}

/* UI */
#deckUI{
  position:absolute;
  left:20px;
  top:50%;
  transform:translateY(-50%);
  z-index:20;
}
.deckBtn{
  background:#1e90ff;
  margin:6px 0;
  padding:10px;
  cursor:pointer;
}
.deckBtn:hover{background:#ffcc00;color:black}

/* CABIN */
#cabin{
  position:absolute;
  inset:0;
  display:none;
  z-index:30;
}
#cabin img{
  width:100%;
  height:100%;
  object-fit:cover;
}
#close{
  position:absolute;
  top:20px;
  right:20px;
  background:red;
  padding:10px;
  cursor:pointer;
}
</style>
</head>

<body>

<div id="deckUI">
  <div class="deckBtn" onclick="moveElevator(12)">Deck 12</div>
  <div class="deckBtn" onclick="moveElevator(11)">Deck 11</div>
  <div class="deckBtn" onclick="moveElevator(10)">Deck 10</div>
</div>

<div id="cabin">
  <div id="close" onclick="closeCabin()">CLOSE</div>
  <!-- BASE64 PLACEHOLDER IMAGE -->
  <img src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTAwMCIgaGVpZ2h0PSI2MDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHJlY3Qgd2lkdGg9IjEwMDAlIiBoZWlnaHQ9IjEwMCUiIGZpbGw9IiMwMDJhNTAiLz48dGV4dCB4PSI1MCUiIHk9IjUwJSIgZmlsbD0id2hpdGUiIGZvbnQtc2l6ZT0iNDAiIHRleHQtYW5jaG9yPSJtaWRkbGUiPkRlbHV4ZSBPY2VhbiBWaWV3PC90ZXh0Pjwvc3ZnPg==" />
</div>

<script>
/* THREE */
const scene=new THREE.Scene();
scene.fog=new THREE.Fog(0x000000,50,200);

const camera=new THREE.PerspectiveCamera(60,innerWidth/innerHeight,0.1,1000);
camera.position.set(0,20,50);

const renderer=new THREE.WebGLRenderer({antialias:true});
renderer.setSize(innerWidth,innerHeight);
document.body.appendChild(renderer.domElement);

const controls=new THREE.OrbitControls(camera,renderer.domElement);
controls.enablePan=false;

/* LIGHT */
scene.add(new THREE.AmbientLight(0xffffff,0.6));
const sun=new THREE.DirectionalLight(0xffffff,1);
sun.position.set(50,80,30);
scene.add(sun);

/* OCEAN */
const ocean=new THREE.Mesh(
  new THREE.PlaneGeometry(600,600),
  new THREE.MeshPhongMaterial({color:0x001a33})
);
ocean.rotation.x=-Math.PI/2;
ocean.position.y=-6;
scene.add(ocean);

/* SHIP */
const ship=new THREE.Group();
scene.add(ship);

/* HULL */
ship.add(new THREE.Mesh(
  new THREE.BoxGeometry(60,10,18),
  new THREE.MeshStandardMaterial({color:0xffffff})
));

/* NOSE */
const bow=new THREE.Mesh(
  new THREE.ConeGeometry(9,18,4),
  new THREE.MeshStandardMaterial({color:0xffffff})
);
bow.rotation.z=Math.PI/2;
bow.position.x=-30;
ship.add(bow);

/* FUNNELS */
for(let i=0;i<4;i++){
  const f=new THREE.Mesh(
    new THREE.CylinderGeometry(2,2.5,10,16),
    new THREE.MeshStandardMaterial({color:0xaa0000})
  );
  f.position.set(-10+i*8,25,0);
  ship.add(f);
}

/* ELEVATOR SHAFT */
const shaft=new THREE.Mesh(
  new THREE.BoxGeometry(3,30,3),
  new THREE.MeshStandardMaterial({color:0x555555})
);
shaft.position.set(10,15,0);
ship.add(shaft);

/* ELEVATOR CAR */
const elevator=new THREE.Mesh(
  new THREE.BoxGeometry(2,2,2),
  new THREE.MeshStandardMaterial({color:0xffcc00})
);
elevator.position.set(10,2,0);
ship.add(elevator);

/* ELEVATOR LOGIC */
let targetY=2;
function moveElevator(deck){
  targetY=deck*2;
  if(deck===12) openCabin();
}

function openCabin(){
  document.getElementById("cabin").style.display="block";
}
function closeCabin(){
  document.getElementById("cabin").style.display="none";
}

/* ANIMATE */
function animate(){
  requestAnimationFrame(animate);
  elevator.position.y+= (targetY-elevator.position.y)*0.05;
  ship.rotation.y+=0.0006;
  renderer.render(scene,camera);
}
animate();

addEventListener("resize",()=>{
  camera.aspect=innerWidth/innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
});
</script>

</body>
</html>
